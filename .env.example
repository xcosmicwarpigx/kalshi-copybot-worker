# Start in weather-only (signal) mode for validation
WEATHER_ONLY_MODE=true
KALSHI_TRADING_ENABLED=false

# Required
BANKROLL_USD=1000
CRON_INTERVAL_MS=300000

# Optional when trading mode is enabled
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2

# Strategy knobs
MIN_EDGE_PCT=0.05
MAX_TRADE_RISK_PCT=0.02
OPEN_METEO_API_BASE=https://api.open-meteo.com

# JSON array string; ticker optional in weather-only mode
WEATHER_LOCATIONS_JSON=[{"id":"den","name":"Denver","latitude":39.7392,"longitude":-104.9903,"side":"yes","thresholdF":70,"resolveHourUtc":0},{"id":"phx","name":"Phoenix","latitude":33.4484,"longitude":-112.074,"side":"yes","thresholdF":85,"resolveHourUtc":0},{"id":"chi","name":"Chicago","latitude":41.8781,"longitude":-87.6298,"side":"yes","thresholdF":60,"resolveHourUtc":0}]
